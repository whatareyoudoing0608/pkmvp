# Environment Configuration Example
# Copy this file to .env and fill in your values

# ===== Backend (.NET Core API) =====
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:80

# JWT Configuration
Jwt__Key=your-super-secret-jwt-key-at-least-32-characters-long

# Database Configuration
Database__ConnectionString=Data Source=your-oracle-server;User Id=username;Password=password;

# Oracle Configuration
Oracle__BindByName=true

# ===== Frontend (React) =====
# API Base URL (change if backend runs on different host)
VITE_API_BASE_URL=http://localhost:5000

# ===== Application Settings =====
# Logging
LOGGING_LEVEL=Information

# CORS
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000

# ===== Docker Compose Overrides =====
# Container restart policy
RESTART_POLICY=unless-stopped

# Network
DOCKER_NETWORK=pkmvp-network

# ===== Production Settings =====
# For production, use strong JWT key and secure database connection
# Example: 
# Jwt__Key=abcdef1234567890abcdef1234567890abcdef1234567890
